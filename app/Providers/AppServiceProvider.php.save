     */
    public function boot(): void
    {
        // 💡 TAMBAHKAN BARIS INI BIAR FORM LOGIN NYA TERPAKSA PAKAI HTTPS:
        if (config('app.env') === 'production' || true) {
            URL::forceScheme('https');
        }
    }
